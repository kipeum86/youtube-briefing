---
/**
 * BriefingCard — single briefing article.
 *
 * Renders OK briefings with inline expand/collapse, and failed briefings as
 * a de-emphasized card with the failure reason. The expand button is a
 * semantic <button aria-expanded>, not a link.
 *
 * Props:
 *   - briefing: the Briefing data (from astro:content)
 *   - isFirst: show the unread rule on the first card of the feed (heuristic
 *              until localStorage read-tracking kicks in on the client)
 */

import type { CollectionEntry } from "astro:content";

interface Props {
  briefing: CollectionEntry<"briefing">;
}

const { briefing } = Astro.props;
const data = briefing.data;

// Format published_at as "2026.04.09" (KST)
function formatKstDate(iso: Date): string {
  const kstMs = iso.getTime() + 9 * 60 * 60 * 1000;
  const k = new Date(kstMs);
  const y = k.getUTCFullYear();
  const m = String(k.getUTCMonth() + 1).padStart(2, "0");
  const d = String(k.getUTCDate()).padStart(2, "0");
  return `${y}.${m}.${d}`;
}

const dateStr = formatKstDate(data.published_at);
const isFailed = data.status === "failed";
const cardId = `briefing-${data.video_id}`;

// Failure reason → Korean display string (mirrors Pydantic FailureReason enum)
const failureMessages: Record<string, string> = {
  session_expired: "일시적 인증 문제",
  video_removed: "영상이 삭제되었거나 비공개",
  members_only: "멤버십 전용 영상",
  age_restricted: "연령 제한 영상",
  empty_transcript: "음성 없음 또는 추출 불가",
  transcripts_disabled: "자막이 비활성화된 영상",
  summarizer_refused: "요약 처리 실패",
  wrong_language: "요약 언어 오류",
};

const failureDisplay = isFailed && data.failure_reason
  ? failureMessages[data.failure_reason] ?? data.failure_reason
  : null;

/**
 * Parse a Gemini-produced summary into a structured shape.
 *
 * The prompt spec in pipeline/summarizers/gemini_flash.py asks the model to
 * produce:
 *   **주제 한 줄**            (15자 이내 headline, 개조식)
 *   <blank line>
 *   핵심 주장 3~4문장
 *   <blank line>
 *   근거/데이터 4~6문장
 *   <blank line>
 *   함의 2~3문장
 *
 * The model occasionally drifts and writes section labels like "**1. 주제 한 줄**"
 * or "**핵심 주장**" as their own paragraph. We strip those before rendering.
 *
 * Each surviving body paragraph may also contain inline `**bold**` markdown
 * spans (Gemini reaches for them naturally for emphasis). We render those as
 * <strong> tags via a tiny safe parser. We deliberately don't pull in a real
 * markdown library — only `**bold**` is in scope, everything else stays plain.
 */
interface SummarySegment {
  text: string;
  bold: boolean;
}

interface ParsedSummary {
  headline: string | null;
  paragraphs: SummarySegment[][];
}

// Section-label paragraphs the model sometimes inserts as their own block.
// Examples seen in production: "**1. 주제 한 줄**", "**핵심 주장**", "주제: ..."
const SECTION_LABEL_PATTERNS: RegExp[] = [
  /^\*{0,2}\s*(\d+\.\s*)?(주제\s*한\s*줄|핵심\s*주장|근거\s*\/?\s*데이터|함의|결론|요약)\s*\*{0,2}\s*$/,
  /^#+\s*/,  // markdown headers like "## 핵심 주장"
];

function isSectionLabel(text: string): boolean {
  return SECTION_LABEL_PATTERNS.some((re) => re.test(text.trim()));
}

/**
 * Convert a paragraph string into a list of {text, bold} segments by walking
 * the string and toggling on every `**` pair. This is intentionally minimal —
 * doesn't handle nested markdown, escaped asterisks, or any other inline
 * markup. The output is rendered as a sequence of <span>/<strong> children
 * by Astro's JSX renderer, so there's no innerHTML/XSS risk.
 */
function parseInlineBold(paragraph: string): SummarySegment[] {
  const segments: SummarySegment[] = [];
  // Match either **bold** spans or any other run of characters.
  const re = /\*\*([^*]+)\*\*|([^*]+|\*)/g;
  let match: RegExpExecArray | null;
  while ((match = re.exec(paragraph)) !== null) {
    if (match[1] !== undefined) {
      segments.push({ text: match[1], bold: true });
    } else if (match[2] !== undefined && match[2].length > 0) {
      segments.push({ text: match[2], bold: false });
    }
  }
  return segments;
}

function parseSummary(summary: string): ParsedSummary {
  const trimmed = summary.trim();
  if (!trimmed) return { headline: null, paragraphs: [] };

  const rawBlocks = trimmed
    .split(/\n\s*\n+/)
    .map((b) => b.trim())
    .filter((b) => b.length > 0);

  if (rawBlocks.length === 0) return { headline: null, paragraphs: [] };

  // Pull off an opening **headline** if it's a single short line wrapped in **.
  let headline: string | null = null;
  let bodyBlocks = rawBlocks;
  const firstHeader = rawBlocks[0].match(/^\*\*(.+?)\*\*\s*$/s);
  if (firstHeader && firstHeader[1].length < 80 && !firstHeader[1].includes("\n")) {
    headline = firstHeader[1].trim();
    bodyBlocks = rawBlocks.slice(1);
  }

  // Drop any section-label paragraphs Gemini may have leaked through, then
  // parse inline **bold** spans on the survivors.
  const paragraphs = bodyBlocks
    .filter((b) => !isSectionLabel(b))
    .map((b) => parseInlineBold(b))
    .filter((segs) => segs.length > 0);

  return { headline, paragraphs };
}

/**
 * Produce the collapsed-card preview text. Operates on the parsed summary so
 * the preview never includes literal `**` or section labels.
 */
function cleanPreview(summary: string | null): string {
  if (!summary) return "";
  const parsed = parseSummary(summary);
  const firstSegs = parsed.paragraphs[0];
  const first = firstSegs
    ? firstSegs.map((s) => s.text).join("")
    : parsed.headline ?? "";
  if (first.length <= 180) return first;

  const sliced = first.slice(0, 180);
  // Prefer to end at a Korean sentence-ending punctuation.
  const boundaries = ["다.", "요.", "음.", ".", "!", "?"];
  let bestCut = -1;
  for (const b of boundaries) {
    const idx = sliced.lastIndexOf(b);
    if (idx > bestCut) bestCut = idx + b.length;
  }
  if (bestCut > 100) {
    return first.slice(0, bestCut).trim() + " …";
  }
  return sliced + "…";
}

const parsedSummary: ParsedSummary = !isFailed && data.summary
  ? parseSummary(data.summary)
  : { headline: null, paragraphs: [] };
---

<article
  class:list={["briefing", "unread", { failed: isFailed }]}
  id={`v-${data.video_id}`}
  data-channel={data.channel_slug}
  data-video-id={data.video_id}
  data-expanded="false"
  aria-labelledby={`${cardId}-title`}>
  <div class="meta">
    <span class="channel">{data.channel_name}</span>
    <span class="sep">/</span>
    <span class="date">{dateStr}</span>
    {isFailed && <span class="status-failed">요약 실패</span>}
  </div>

  <h2 id={`${cardId}-title`}>{data.title}</h2>

  {
    isFailed ? (
      <p class="preview">
        이 영상은 요약하지 못했습니다. 원본 영상에서 직접 확인하세요.
        {failureDisplay && ` (이유: ${failureDisplay})`}
      </p>
    ) : (
      <>
        <p class="preview">{cleanPreview(data.summary)}</p>
        <div class="full-summary">
          {parsedSummary.headline && (
            <h3 class="full-summary-headline">{parsedSummary.headline}</h3>
          )}
          {parsedSummary.paragraphs.map((segments) => (
            <p>
              {segments.map((seg) =>
                seg.bold ? <strong>{seg.text}</strong> : seg.text,
              )}
            </p>
          ))}
        </div>
      </>
    )
  }

  <div class="actions">
    {
      !isFailed && (
        <button
          type="button"
          aria-expanded="false"
          aria-controls={`${cardId}-body`}
          data-expand-button>
          펼쳐보기
        </button>
      )
    }
    <a href={data.video_url} target="_blank" rel="noopener noreferrer">원본 영상</a>
  </div>
</article>
