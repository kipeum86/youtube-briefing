# Gemini API key — required
# Get one at https://aistudio.google.com/apikey (free tier is plenty)
GEMINI_API_KEY=

# NotebookLM auth — OPTIONAL
# Only needed as a fallback for videos where youtube-transcript-api fails.
# Most users don't need this. If you want it, paste the JSON content of
# your Playwright storage_state.json here as a single line.
# NOTEBOOKLM_AUTH_JSON=
