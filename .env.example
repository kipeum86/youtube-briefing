# Gemini API key — REQUIRED
# Get one at https://aistudio.google.com/apikey (free tier is plenty)
GEMINI_API_KEY=

# NotebookLM authentication — REQUIRED
#
# This project uses NotebookLM as the primary transcript source because
# youtube-transcript-api and yt-dlp both get IP-blocked from cloud runner
# ranges. NotebookLM rides on a logged-in Google session instead.
#
# Two ways to set it up:
#
# 1. Interactive login (recommended for local development):
#      pip install notebooklm-py
#      notebooklm login
#    This writes ~/.notebooklm/storage_state.json. The pipeline reads that
#    file by default — no env var needed. Re-run `notebooklm login` when
#    the session expires (every few weeks).
#
# 2. Inline JSON (for deployment on another machine):
#    Paste the full content of storage_state.json as a single line below.
#    This takes precedence over the ~/.notebooklm/storage_state.json file.
#
# NOTEBOOKLM_AUTH_JSON=
